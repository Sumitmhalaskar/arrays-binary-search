class Solution {
public:
    int search(vector<int>& nums, int target) {
       int low = 0;
       int high = nums.size()-1;
       int last = nums[nums.size()-1];
       while(low<=high){
        //   int mid = low+high/2;
        int mid = low + (high - low) / 2;
          if(nums[mid] == target){
             return mid;
          }
          if(nums[mid]>last){
            if(target>nums[mid]){
                low = mid+1;
            }
            else{
                if(target>=nums[0]){
                    high = mid-1;
                }
                else{
                    low = mid+1;
                }
            }
          }
          else{
            if(nums[mid]>target){
                high = mid-1;
            }
            else{
               if(target<=last){
                 low = mid+1;
               } 
               else{
                 high = mid-1;
               }
            }
          }
       }
       return -1;
    }
};
