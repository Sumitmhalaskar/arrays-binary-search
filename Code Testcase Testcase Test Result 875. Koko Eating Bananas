class Solution {
public:
    double fun(vector<int>a,int n,int speed){
        int h = 0;
        for( int i=0;i<n;i++){
            h = h+a[i]/speed;
            if(a[i]%speed!=0){
                h++;
            }
        }
        return h;
    }
    int minEatingSpeed(vector<int>& piles, int h) {
        int low = 1;
        int n = piles.size();
        int high = *max_element(piles.begin(),piles.end());
        int  res = -1;
        while(low<=high){
            int mid = low + (high - low) / 2;
            int hour = fun(piles,n,mid);
            if(hour>h){
                low = mid+1;
            }
            else{
                res = mid;
                high = mid-1;
            }
        }
        return res;
    }
};
